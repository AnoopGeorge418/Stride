{
  "expo": {
    "name": "Stride",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "../assets/fonts/Playfair_Black.ttf",
            "../assets/fonts/Playfair_Bold.ttf",
            "../assets/fonts/Playfair_ExtraBold.ttf",
            "../assets/fonts/Playfair_Light.ttf",
            "../assets/fonts/Playfair_Medium.ttf",
            "../assets/fonts/Playfair_Regular.ttf",
  
            "../assets/fonts/PlayfairDisplay_Black.ttf",
            "../assets/fonts/PlayfairDisplay_Bold.ttf",
            "../assets/fonts/PlayfairDisplay_ExtraBold.ttf",
            "../assets/fonts/PlayfairDisplay_Medium.ttf",
            "../assets/fonts/PlayfairDisplay_Regular.ttf"
          ]
        }
      ],
      [
        "expo-image",
        {
          "disableLibdav1d": true
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
